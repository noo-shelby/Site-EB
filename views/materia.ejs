<!DOCTYPE html>
<html lang="pt-br">
<head>
    <link rel="stylesheet" href="/style.css">
    <title><%= noticia.titulo %></title>
</head>
<body>
    <div class="container">
        <h1><%= noticia.titulo %></h1>
        <h3><%= noticia.subtitulo %></h3>
        <hr>
        <p><%= noticia.conteudo %></p>
        <p><strong>Assinado por: <%= noticia.autor %></strong></p>
        <hr>
        <h3>Comentários</h3>
        <% if (user) { %>
            <form action="/comentar/<%= noticia.id %>" method="POST">
                <textarea name="texto" required style="width:100%"></textarea><br>
                <button type="submit">Enviar</button>
            </form>
        <% } %>
        <% comentarios.forEach(c => { %>
            <div style="border:1px solid #ccc; margin:10px; padding:10px;">
                <strong><%= c.usuario_nome %>:</strong> <%= c.texto %>
            </div>
        <% }) %>
        <br><a href="/">Voltar</a>
    </div>
</body>
</html>
