<!DOCTYPE html>
<html lang="pt-br">
<head>
    <link rel="stylesheet" href="/style.css">
    <title>Painel Admin</title>
</head>
<body>
    <div class="container">
        <h1>Gestão de Membros</h1>
        <table>
            <thead>
                <tr>
                    <th>Militar</th>
                    <th>Cargo</th>
                    <th>ADVs</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                <% logs.forEach(l => { %>
                <tr>
                    <td><%= l.login %></td>
                    <td>
                        <form action="/admin/alterar-cargo/<%= l.id %>" method="POST">
                            <select name="novo_cargo" onchange="this.form.submit()">
                                <option value="Membro" <%= l.cargo==='Membro'?'selected':'' %>>Membro</option>
                                <option value="Jornalista" <%= l.cargo==='Jornalista'?'selected':'' %>>Jornalista</option>
                                <option value="Moderador" <%= l.cargo==='Moderador'?'selected':'' %>>Moderador</option>
                                <option value="Administrador" <%= l.cargo==='Administrador'?'selected':'' %>>Administrador</option>
                            </select>
                        </form>
                    </td>
                    <td><%= l.advs %>/3</td>
                    <td>
                        <form action="/admin/adv/<%= l.id %>" method="POST" style="display:inline;">
                            <button type="submit" style="background:orange; color:white;">+1 ADV</button>
                        </form>
                        <form action="/admin/banir-direto/<%= l.id %>" method="POST" style="display:inline;">
                            <button type="submit" style="background:black; color:red;">BANIR</button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <br><a href="/">Voltar</a>
    </div>
</body>
</html>
