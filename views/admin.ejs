<!DOCTYPE html>
<html lang="pt-br">
<head>
    <link rel="stylesheet" href="/style.css">
    <title>Admin | CComEX</title>
</head>
<body>
    <div class="container">
        <h1>Gestão de Membros</h1>
        <table border="1" width="100%" style="background:white; text-align:center;">
            <tr>
                <th>Login</th><th>Setor</th><th>Cargo</th><th>ADVs</th><th>Ações</th>
            </tr>
            <% logs.forEach(l => { %>
                <tr>
                    <td><%= l.login %></td>
                    <td><%= l.setor %></td>
                    <td>
                        <form action="/admin/alterar-cargo/<%= l.id %>" method="POST">
                            <select name="novo_cargo" onchange="this.form.submit()">
                                <option value="Membro" <%= l.cargo==='Membro'?'selected':'' %>>Membro</option>
                                <option value="Jornalista" <%= l.cargo==='Jornalista'?'selected':'' %>>Jornalista</option>
                                <option value="Moderador" <%= l.cargo==='Moderador'?'selected':'' %>>Moderador</option>
                                <option value="Administrador" <%= l.cargo==='Administrador'?'selected':'' %>>Administrador</option>
                            </select>
                        </form>
                    </td>
                    <td><%= l.advs %>/3</td>
                    <td>
                        <form action="/admin/adv/<%= l.id %>" method="POST">
                            <button type="submit" style="background:orange;">+1 ADV</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </table>
        <br><a href="/">Voltar</a>
    </div>
</body>
</html>
