<!DOCTYPE html>
<html lang="pt-br">
<head>
    <link rel="stylesheet" href="/style.css">
    <title>Cadastro</title>
</head>
<body>
    <div class="container">
        <div class="card-noticia" style="max-width:400px; margin:auto;">
            <h2>Alistamento</h2>
            <form action="/cadastro" method="POST">
                <input type="text" name="discord_user" placeholder="Discord#0000" required>
                <input type="text" name="setor" placeholder="Setor" required>
                <input type="text" name="login" placeholder="Nome de Usuário" required>
                <input type="password" name="senha" placeholder="Senha" required>
                <button type="submit" style="background:#2e3b23; color:white; width:100%;">CADASTRAR</button>
            </form>
        </div>
    </div>
</body>
</html>
